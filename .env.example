# Supabase (create a NEW project — do not reuse RingBack's)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Shared number that receives the "5551234567 Mike" SMS-in trigger texts
TWILIO_INBOUND_TRIGGER_NUMBER=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# The monthly subscription Price ID from your Stripe product
STRIPE_PRICE_ID=

# Your own cell number — gets a text if a signup's Twilio number provisioning
# fails in the background, so a stuck customer doesn't go unnoticed
ADMIN_ALERT_PHONE=

# Your deployed app URL, used to build the /r/[requestId] tracked links
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
